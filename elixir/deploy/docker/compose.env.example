# Compose interpolation values for elixir/deploy/docker/docker-compose.yml
SYMPHONY_COMPOSE_PROJECT=symphony
SYMPHONY_IMAGE=ghcr.io/maximlafe/symphony:sha-REPLACE_ME
SYMPHONY_CONTAINER_NAME=symphony

CODEX_HOME=/root/.codex
SYMPHONY_CODEX_HOME_HOST_PATH=/srv/symphony/codex-home

SYMPHONY_WORKFLOW_HOST_PATH=/srv/symphony/workflows
SYMPHONY_WORKFLOW_PATH=/srv/symphony/workflows/WORKFLOW.md

SYMPHONY_PORT=4101
SYMPHONY_SERVER_HOST=0.0.0.0
SYMPHONY_SERVER_PATH=/proxy/symphony
SYMPHONY_PUBLIC_HOST=stream.cash
SYMPHONY_PUBLIC_PATH=/proxy/symphony

SYMPHONY_WORKSPACE_ROOT=/srv/symphony/workspaces
SYMPHONY_WORKSPACE_HOST_PATH=/srv/symphony/workspaces
SYMPHONY_LOGS_ROOT=/srv/symphony/logs
SYMPHONY_LOGS_HOST_PATH=/srv/symphony/logs

SYMPHONY_SOURCE_REPO_URL=https://github.com/maximlafe/symphony.git
SYMPHONY_RUNTIME_ENV_FILE=/etc/symphony/symphony.env
SYMPHONY_REQUIRED_ENV_VARS=LINEAR_API_KEY GH_TOKEN OPENAI_API_KEY SYMPHONY_SECRET_KEY_BASE SYMPHONY_PUBLIC_HOST
