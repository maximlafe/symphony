# Runtime secrets and tokens loaded into the container by env_file.
LINEAR_API_KEY=lin_api_xxx
GH_TOKEN=ghp_xxx
OPENAI_API_KEY=sk-xxx

# Generate with: openssl rand -hex 64
SYMPHONY_SECRET_KEY_BASE=replace-with-a-long-random-secret

# Optional override. Defaults to //${SYMPHONY_PUBLIC_HOST} in production.
# SYMPHONY_CHECK_ORIGIN=//stream.cash

